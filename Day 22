Q85. Check Palindrome String
Problem Statement
Write a C program to check whether a string is a palindrome or not.

Code
#include <stdio.h>
#include <string.h>

int main() {
    char str[100];
    int i, len, flag = 1;

    printf("Enter a string: ");
    scanf("%s", str);

    len = strlen(str);

    for(i = 0; i < len / 2; i++) {
        if(str[i] != str[len - i - 1]) {
            flag = 0;
            break;
        }
    }

    if(flag)
        printf("Palindrome String\n");
    else
        printf("Not a Palindrome String\n");

    return 0;
}

Output
Enter a string: madam
Palindrome String

Q86. Count Words in a Sentence
Problem Statement
Write a C program to count the number of words in a sentence.

Code
#include <stdio.h>

int main() {
    char str[200];
    int i = 0, words = 1;

    printf("Enter a sentence: ");
    fgets(str, sizeof(str), stdin);

    while(str[i] != '\0') {
        if(str[i] == ' ')
            words++;
        i++;
    }

    printf("Number of words = %d\n", words);

    return 0;
}

