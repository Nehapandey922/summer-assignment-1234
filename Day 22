Q87. Character Frequency
Problem Statement
Write a C program to find the frequency of each character in a string.

Code
#include <stdio.h>
#include <string.h>

int main() {
    char str[100];
    int i, freq[256] = {0};

    printf("Enter a string: ");
    fgets(str, sizeof(str), stdin);

    for(i = 0; str[i] != '\0'; i++) {
        freq[(int)str[i]]++;
    }

    printf("\nCharacter Frequencies:\n");

    for(i = 0; i < 256; i++) {
        if(freq[i] != 0 && i != '\n')
            printf("%c = %d\n", i, freq[i]);
    }

    return 0;
}

Output
Enter a string: hello

Character Frequencies:
h = 1
e = 1
l = 2
o = 1

Q88. Remove Spaces from String
Problem Statement
Write a C program to remove all spaces from a string.

Code
#include <stdio.h>

int main() {
    char str[100], result[100];
    int i = 0, j = 0;

    printf("Enter a string: ");
    fgets(str, sizeof(str), stdin);

    while(str[i] != '\0') {
        if(str[i] != ' ' && str[i] != '\n') {
            result[j++] = str[i];
        }
        i++;
    }

    result[j] = '\0';

    printf("String after removing spaces: %s\n", result);

    return 0;
}

Output
Enter a string: C Programming Language
String after removing spaces: CProgrammingLanguage