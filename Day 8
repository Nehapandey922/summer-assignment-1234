Q29. Write a program to print Half Pyramid Pattern.
Problem Statement
Write a C program to print the following half pyramid:
*
**
***
****
*****

Code
#include <stdio.h>

int main()
{
    int i, j;

    for(i = 1; i <= 5; i++)
    {
        for(j = 1; j <= i; j++)
        {
            printf("*");
        }
        printf("\n");
    }

    return 0;
}

Output
*
**
***
****
*****

Q30. Write a program to print Number Triangle.
Problem Statement
Print the following pattern:
1
12
123
1234
12345

Code
#include <stdio.h>

int main()
{
    int i, j;

    for(i = 1; i <= 5; i++)
    {
        for(j = 1; j <= i; j++)
        {
            printf("%d", j);
        }
        printf("\n");
    }

    return 0;
}

Output
1
12
123
1234
12345

Q31. Write a program to print Character Triangle.
Problem Statement
Print the following pattern:
A
AB
ABC
ABCD
ABCDE

Code
#include <stdio.h>

int main()
{
    int i, j;

    for(i = 1; i <= 5; i++)
    {
        for(j = 0; j < i; j++)
        {
            printf("%c", 'A' + j);
        }
        printf("\n");
    }

    return 0;
}

Output
A
AB
ABC
ABCD
ABCDE

