Q37. Write a program to print a star pyramid.

Code
#include <stdio.h>

int main()
{
    int i, j, rows = 5;

    for(i = 1; i <= rows; i++)
    {
        for(j = 1; j <= rows - i; j++)
            printf(" ");

        for(j = 1; j <= (2 * i - 1); j++)
            printf("*");

        printf("\n");
    }

    return 0;
}

Output
    *
   ***
  *****
 *******
*********
Q38. Write a program to print a reverse star pyramid.

Code
#include <stdio.h>

int main()
{
    int i, j, rows = 5;

    for(i = rows; i >= 1; i--)
    {
        for(j = 1; j <= rows - i; j++)
            printf(" ");

        for(j = 1; j <= (2 * i - 1); j++)
            printf("*");

        printf("\n");
    }

    return 0;
}

Output
*********
 *******
  *****
   ***
    *
Q39. Write a program to print a number pyramid.

Code
#include <stdio.h>

int main()
{
    int i, j;

    for(i = 1; i <= 5; i++)
    {
        for(j = 1; j <= i; j++)
            printf("%d", j);

        for(j = i - 1; j >= 1; j--)
            printf("%d", j);

        printf("\n");
    }

    return 0;
}

Output
1
121
12321
1234321
123454321
Q40. Write a program to print a character pyramid.

Code
#include <stdio.h>

int main()
{
    int i, j;
    char ch;

    for(i = 1; i <= 5; i++)
    {
        ch = 'A';

        for(j = 1; j <= i; j++)
        {
            printf("%c", ch);
            ch++;
        }

        ch -= 2;

        for(j = 1; j < i; j++)
        {
            printf("%c", ch);
            ch--;
        }

        printf("\n");
    }

    return 0;
}

Output
A
ABA
ABCBA
ABCDCBA
ABCDEDCBA