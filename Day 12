Q48. Write a program to write a function for Perfect Number.

Code
#include <stdio.h>

int perfect(int n)
{
    int sum = 0;

    for (int i = 1; i < n; i++)
    {
        if (n % i == 0)
            sum += i;
    }

    return sum == n;
}

int main()
{
    int num;

    printf("Enter a number: ");
    scanf("%d", &num);

    if (perfect(num))
        printf("%d is a Perfect Number.", num);
    else
        printf("%d is not a Perfect Number.", num);

    return 0;
}

Output
Enter a number: 28
28 is a Perfect Number.