Q65. Write a Program to Merge Two Arrays

Code
#include <stdio.h>

int main() {
    int a[50], b[50], c[100];
    int n1, n2, i;

    printf("Enter size of first array: ");
    scanf("%d", &n1);

    printf("Enter elements of first array:\n");
    for(i = 0; i < n1; i++)
        scanf("%d", &a[i]);

    printf("Enter size of second array: ");
    scanf("%d", &n2);

    printf("Enter elements of second array:\n");
    for(i = 0; i < n2; i++)
        scanf("%d", &b[i]);

    for(i = 0; i < n1; i++)
        c[i] = a[i];

    for(i = 0; i < n2; i++)
        c[n1 + i] = b[i];

    printf("Merged Array: ");
    for(i = 0; i < n1 + n2; i++)
        printf("%d ", c[i]);

    return 0;
}

Output
Enter size of first array: 3
Enter elements of first array:
1 2 3
Enter size of second array: 3
Enter elements of second array:
4 5 6
Merged Array: 1 2 3 4 5 6

Q66. Write a Program to Find Union of Two Arrays

Code
#include <stdio.h>

int main() {
    int a[50], b[50], i, j, n1, n2, found;

    printf("Enter size of first array: ");
    scanf("%d", &n1);

    printf("Enter elements:\n");
    for(i = 0; i < n1; i++)
        scanf("%d", &a[i]);

    printf("Enter size of second array: ");
    scanf("%d", &n2);

    printf("Enter elements:\n");
    for(i = 0; i < n2; i++)
        scanf("%d", &b[i]);

    printf("Union: ");

    for(i = 0; i < n1; i++)
        printf("%d ", a[i]);

    for(i = 0; i < n2; i++) {
        found = 0;
        for(j = 0; j < n1; j++) {
            if(b[i] == a[j]) {
                found = 1;
                break;
            }
        }
        if(!found)
            printf("%d ", b[i]);
    }

    return 0;
}

Output
Enter size of first array: 4
Enter elements:
1 2 3 4
Enter size of second array: 4
Enter elements:
3 4 5 6
Union: 1 2 3 4 5 6

Q67. Write a Program to Find Intersection of Two Arrays

Code
#include <stdio.h>

int main() {
    int a[50], b[50];
    int n1, n2, i, j;

    printf("Enter size of first array: ");
    scanf("%d", &n1);

    printf("Enter elements:\n");
    for(i = 0; i < n1; i++)
        scanf("%d", &a[i]);

    printf("Enter size of second array: ");
    scanf("%d", &n2);

    printf("Enter elements:\n");
    for(i = 0; i < n2; i++)
        scanf("%d", &b[i]);

    printf("Intersection: ");

    for(i = 0; i < n1; i++) {
        for(j = 0; j < n2; j++) {
            if(a[i] == b[j]) {
                printf("%d ", a[i]);
                break;
            }
        }
    }

    return 0;
}

Output
Enter size of first array: 4
Enter elements:
1 2 3 4
Enter size of second array: 4
Enter elements:
3 4 5 6
Intersection: 3 4

