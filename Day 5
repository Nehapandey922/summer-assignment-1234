Q17. Write a program to Check Perfect Number.

Program
#include <stdio.h>

int main() {
    int num, i, sum = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    for(i = 1; i < num; i++) {
        if(num % i == 0)
            sum += i;
    }

    if(sum == num)
        printf("%d is a Perfect Number.", num);
    else
        printf("%d is Not a Perfect Number.", num);

    return 0;
}

Sample Output
Enter a number: 28
28 is a Perfect Number.

Q18. Write a program to Check Strong Number.

Program
#include <stdio.h>

int main() {
    int num, temp, rem, i;
    int sum = 0, fact;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;

    while(temp > 0) {
        rem = temp % 10;
        fact = 1;

        for(i = 1; i <= rem; i++)
            fact *= i;

        sum += fact;
        temp /= 10;
    }

    if(sum == num)
        printf("%d is a Strong Number.", num);
    else
        printf("%d is Not a Strong Number.", num);

    return 0;
}

Sample Output
Enter a number: 145
145 is a Strong Number.

Q19. Write a program to Print Factors of a Number.

Program
#include <stdio.h>

int main() {
    int num, i;

    printf("Enter a number: ");
    scanf("%d", &num);

    printf("Factors of %d are:\n", num);

    for(i = 1; i <= num; i++) {
        if(num % i == 0)
            printf("%d ", i);
    }

    return 0;
}

Sample Output
Enter a number: 12
Factors of 12 are:
1 2 3 4 6 12

Q20. Write a program to Find Largest Prime Factor.

Program
#include <stdio.h>

int main() {
    long long num;
    long long largest = 1;

    printf("Enter a number: ");
    scanf("%lld", &num);

    while(num % 2 == 0) {
        largest = 2;
        num /= 2;
    }

    for(long long i = 3; i * i <= num; i += 2) {
        while(num % i == 0) {
            largest = i;
            num /= i;
        }
    }

    if(num > 2)
        largest = num;

    printf("Largest Prime Factor = %lld", largest);

    return 0;
}

Sample Output
Enter a number: 84
Largest Prime Factor = 7