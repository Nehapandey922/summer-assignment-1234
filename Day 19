📌 Q73. Write a program to Add Two Matrices.

💻 Code
#include <stdio.h>

int main() {
    int a[2][2], b[2][2], sum[2][2];

    printf("Enter first matrix:\n");
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&a[i][j]);

    printf("Enter second matrix:\n");
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&b[i][j]);

    printf("Sum Matrix:\n");
    for(int i=0;i<2;i++){
        for(int j=0;j<2;j++){
            sum[i][j]=a[i][j]+b[i][j];
            printf("%d ",sum[i][j]);
        }
        printf("\n");
    }

    return 0;
}

🖥️ Output
Enter first matrix:
1 2
3 4
Enter second matrix:
5 6
7 8

Sum Matrix:
6 8
10 12

📌 Q74. Write a program to Subtract Two Matrices.

💻 Code
#include <stdio.h>

int main() {
    int a[2][2], b[2][2], sub[2][2];

    printf("Enter first matrix:\n");
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&a[i][j]);

    printf("Enter second matrix:\n");
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&b[i][j]);

    printf("Subtraction Matrix:\n");
    for(int i=0;i<2;i++){
        for(int j=0;j<2;j++){
            sub[i][j]=a[i][j]-b[i][j];
            printf("%d ",sub[i][j]);
        }
        printf("\n");
    }

    return 0;
}

