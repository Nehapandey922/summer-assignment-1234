📌 Q75. Write a program to Find the Transpose of a Matrix.

💻 Code
#include <stdio.h>

int main() {
    int a[2][2];

    printf("Enter matrix:\n");
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&a[i][j]);

    printf("Transpose Matrix:\n");

    for(int i=0;i<2;i++){
        for(int j=0;j<2;j++)
            printf("%d ",a[j][i]);
        printf("\n");
    }

    return 0;
}

🖥️ Output
Enter matrix:
1 2
3 4

Transpose Matrix:
1 3
2 
📌 Q76. Write a program to Find the Diagonal Sum of a Matrix.

💻 Code
#include <stdio.h>

int main() {
    int a[3][3], sum=0;

    printf("Enter 3x3 matrix:\n");

    for(int i=0;i<3;i++)
        for(int j=0;j<3;j++)
            scanf("%d",&a[i][j]);

    for(int i=0;i<3;i++)
        sum += a[i][i];

    printf("Diagonal Sum = %d",sum);

    return 0;
}

