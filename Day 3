Q9. Write a program to check whether a number is Prime.
C Program

#include <stdio.h>

int main() {
    int n, i, prime = 1;

    printf("Enter a number: ");
    scanf("%d", &n);

    if (n <= 1) {
        prime = 0;
    } else {
        for (i = 2; i <= n / 2; i++) {
            if (n % i == 0) {
                prime = 0;
                break;
            }
        }
    }

    if (prime)
        printf("%d is a Prime Number.\n", n);
    else
        printf("%d is Not a Prime Number.\n", n);

    return 0;
}

Sample Output
Enter a number: 17
17 is a Prime Number.

Q10. Write a program to print Prime numbers in a given range.
C Program

#include <stdio.h>

int main() {
    int start, end, i, j, prime;

    printf("Enter starting number: ");
    scanf("%d", &start);

    printf("Enter ending number: ");
    scanf("%d", &end);

    printf("Prime numbers are:\n");

    for (i = start; i <= end; i++) {
        if (i < 2)
            continue;

        prime = 1;

        for (j = 2; j <= i / 2; j++) {
            if (i % j == 0) {
                prime = 0;
                break;
            }
        }

        if (prime)
            printf("%d ", i);
    }

    return 0;
}

Sample Output
Enter starting number: 10
Enter ending number: 30
Prime numbers are:
11 13 17 19 23 29

Q11. Write a program to find GCD (Greatest Common Divisor) of two numbers.
C Program

#include <stdio.h>

int main() {
    int a, b, i, gcd;

    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    for (i = 1; i <= a && i <= b; i++) {
        if (a % i == 0 && b % i == 0)
            gcd = i;
    }

    printf("GCD = %d\n", gcd);

    return 0;
}

Sample Output
Enter two numbers: 24 36
GCD = 12

Q12. Write a program to find LCM (Least Common Multiple) of two numbers.
C Program

#include <stdio.h>

int main() {
    int a, b, max;

    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    max = (a > b) ? a : b;

    while (1) {
        if (max % a == 0 && max % b == 0) {
            printf("LCM = %d\n", max);
            break;
        }
        max++;
    }

    return 0;
}

Sample Output
Enter two numbers: 12 18
LCM = 36