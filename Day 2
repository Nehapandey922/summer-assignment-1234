Q5. Write a program to find the sum of digits of a number.

Program
#include <stdio.h>

int main() {
    int num, sum = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    while (num != 0) {
        sum = sum + num % 10;
        num = num / 10;
    }

    printf("Sum of digits = %d", sum);

    return 0;
}

Output
Enter a number: 1234
Sum of digits = 10

Explanation
Take the last digit using % 10.
Add it to sum.
Remove the last digit using / 10.
Repeat until the number becomes 0.

Q6. Write a program to reverse a number.

Program
#include <stdio.h>

int main() {
    int num, reverse = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    while (num != 0) {
        reverse = reverse * 10 + num % 10;
        num = num / 10;
    }

    printf("Reversed Number = %d", reverse);

    return 0;
}

Output
Enter a number: 12345
Reversed Number = 54321

Explanation
Extract the last digit.
Add it to the reversed number.
Continue until the original number becomes 0.

Q7. Write a program to find the product of digits.

Program
#include <stdio.h>

int main() {
    int num, product = 1;

    printf("Enter a number: ");
    scanf("%d", &num);

    while (num != 0) {
        product = product * (num % 10);
        num = num / 10;
    }

    printf("Product of digits = %d", product);

    return 0;
}

Output
Enter a number: 234
Product of digits = 24

Explanation
Multiply each extracted digit.
Store the result in product.

Q8. Write a program to check whether a number is palindrome.

Program
#include <stdio.h>

int main() {
    int num, original, reverse = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    original = num;

    while (num != 0) {
        reverse = reverse * 10 + num % 10;
        num = num / 10;
    }

    if (original == reverse)
        printf("%d is a Palindrome Number.", original);
    else
        printf("%d is Not a Palindrome Number.", original);

    return 0;
}

Output (Palindrome)
Enter a number: 121
121 is a Palindrome Number.
Output (Not Palindrome)
Enter a number: 123
123 is Not a Palindrome Number.

Explanation
Reverse the number.
Compare the reversed number with the original.
If both are equal, the number is a palindrome.