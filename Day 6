Q21. Write a program to Convert Decimal to Binary.
Problem Statement

Write a C program to convert a decimal number into its binary equivalent.

Code
#include <stdio.h>

int main()
{
    int num, binary[32], i = 0;

    printf("Enter a decimal number: ");
    scanf("%d", &num);

    if (num == 0)
    {
        printf("Binary = 0");
        return 0;
    }

    while (num > 0)
    {
        binary[i] = num % 2;
        num = num / 2;
        i++;
    }

    printf("Binary = ");

    for (int j = i - 1; j >= 0; j--)
    {
        printf("%d", binary[j]);
    }

    return 0;
}

Sample Output
Enter a decimal number: 13
Binary = 1101

Explanation
Divide the number by 2 repeatedly.
Store each remainder.
Print the remainders in reverse order.

Q22. Write a program to Convert Binary to Decimal.
Problem Statement
Write a C program to convert a binary number into its decimal equivalent.

Code
#include <stdio.h>
#include <math.h>

int main()
{
    long long binary;
    int decimal = 0, base = 1, rem;

    printf("Enter a binary number: ");
    scanf("%lld", &binary);

    while (binary > 0)
    {
        rem = binary % 10;
        decimal += rem * base;
        binary /= 10;
        base *= 2;
    }

    printf("Decimal = %d", decimal);

    return 0;
}

Sample Output
Enter a binary number: 1101
Decimal = 13
Explanation

Read the binary number digit by digit.
Multiply each digit by powers of 2.
Add all values to get the decimal number.

Q23. Write a program to Count Set Bits in a Number.
Problem Statement
Write a C program to count the number of set bits (1's) in the binary representation of a number.

Code
#include <stdio.h>

int main()
{
    int num, count = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    while (num > 0)
    {
        if (num % 2 == 1)
            count++;

        num /= 2;
    }

    printf("Number of set bits = %d", count);

    return 0;
}

Sample Output
Enter a number: 13
Number of set bits = 3

Explanation
Convert the number into binary using division by 2.
Count every remainder equal to 1.

Q24. Write a program to Find xⁿ without using pow().
Problem Statement
Write a C program to calculate x raised to the power n without using the pow() function.

Code
#include <stdio.h>

int main()
{
    int x, n;
    long long result = 1;

    printf("Enter base: ");
    scanf("%d", &x);

    printf("Enter exponent: ");
    scanf("%d", &n);

    for (int i = 1; i <= n; i++)
    {
        result *= x;
    }

    printf("%d^%d = %lld", x, n, result);

    return 0;
}

Sample Output
Enter base: 2
Enter exponent: 5
2^5 = 32

Explanation
Initialize the result as 1.
Multiply the base by itself n times using a loop.
Display the final result.