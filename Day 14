Enter array elements:
12 45 67 23 89
Second Largest Element = 67

📌 Q56. Find Duplicate Elements
Question
Write a C program to find duplicate elements in an array.

Code
#include <stdio.h>

int main()
{
    int n, arr[100], i, j;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter array elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    printf("Duplicate elements are:\n");

    for(i = 0; i < n; i++)
    {
        for(j = i + 1; j < n; j++)
        {
            if(arr[i] == arr[j])
            {
                printf("%d\n", arr[i]);
                break;
            }
        }
    }

    return 0;
}

Sample Output
Enter number of elements: 7
Enter array elements:
2 4 6 2 8 4 9

Duplicate elements are:
2